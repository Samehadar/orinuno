{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "orinuno-parse-requests",
  "title": "orinuno — parse requests",
  "tags": ["orinuno", "parse-requests"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pending parse requests",
      "description": "Current rows in PENDING — should drain quickly. Sustained > 0 means RequestWorker is starved.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(orinuno_parse_requests{status=\"PENDING\"})",
          "legendFormat": "PENDING"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Running",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(orinuno_parse_requests{status=\"RUNNING\"})",
          "legendFormat": "RUNNING"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Completed (last 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(orinuno_parse_requests_completed_total{outcome=\"DONE\"}[5m]))",
          "legendFormat": "DONE"
        },
        {
          "refId": "B",
          "expr": "sum(increase(orinuno_parse_requests_completed_total{outcome=\"FAILED\"}[5m]))",
          "legendFormat": "FAILED"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Worker tick p95 (s)",
      "description": "If this stays elevated, the scheduler thread is blocked.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(orinuno_parse_request_worker_tick_seconds{quantile=\"0.95\"})",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Parse-request queue by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "orinuno_parse_requests",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Worker tick latency (p50/p95/p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(orinuno_parse_request_worker_tick_seconds{quantile=\"0.5\"})",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "max(orinuno_parse_request_worker_tick_seconds{quantile=\"0.95\"})",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "max(orinuno_parse_request_worker_tick_seconds{quantile=\"0.99\"})",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Processing latency by outcome (p95)",
      "description": "Time from RequestWorker claim → terminal status. Spikes hint at slow Kodik /search or decoder backpressure.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (outcome) (orinuno_parse_request_processing_seconds{quantile=\"0.95\"})",
          "legendFormat": "{{outcome}} p95"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Completion throughput (req/min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "sum"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(orinuno_parse_requests_completed_total[1m])) * 60",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Kodik tokens by tier",
      "description": "Existing kodik_tokens_count metric — included so you can correlate stable=0 with FAILED bursts.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "kodik_tokens_count",
          "legendFormat": "{{tier}}"
        }
      ]
    }
  ]
}
