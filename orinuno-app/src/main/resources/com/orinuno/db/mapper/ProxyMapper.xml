<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.orinuno.repository.ProxyRepository">

    <resultMap id="proxyResultMap" type="com.orinuno.model.KodikProxy">
        <id property="id" column="id"/>
        <result property="host" column="host"/>
        <result property="port" column="port"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="proxyType" column="proxy_type"/>
        <result property="status" column="status"/>
        <result property="lastUsedAt" column="last_used_at"/>
        <result property="failCount" column="fail_count"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" resultMap="proxyResultMap">
        SELECT * FROM kodik_proxy WHERE id = #{id}
    </select>

    <select id="findAllActive" resultMap="proxyResultMap">
        SELECT * FROM kodik_proxy WHERE status = 'ACTIVE' ORDER BY last_used_at ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO kodik_proxy (host, port, username, password, proxy_type, status)
        VALUES (#{host}, #{port}, #{username}, #{password}, #{proxyType}, #{status})
    </insert>

    <update id="updateStatus">
        UPDATE kodik_proxy SET status = #{status} WHERE id = #{id}
    </update>

    <update id="incrementFailCount">
        UPDATE kodik_proxy SET fail_count = fail_count + 1 WHERE id = #{id}
    </update>

    <update id="updateLastUsedAt">
        UPDATE kodik_proxy SET last_used_at = NOW() WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM kodik_proxy WHERE id = #{id}
    </delete>

</mapper>
