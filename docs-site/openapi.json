{
    "openapi": "3.1.0",
    "info": {
        "title": "Orinuno API",
        "description": "API for parsing video content from Kodik",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8085",
            "description": "Generated server url"
        }
    ],
    "tags": [
        {
            "name": "Content",
            "description": "CRUD operations for parsed Kodik content"
        },
        {
            "name": "Stream",
            "description": "Video streaming proxy"
        },
        {
            "name": "Parse",
            "description": "Trigger parsing and decoding operations"
        },
        {
            "name": "Download",
            "description": "Video download to local storage"
        },
        {
            "name": "Export",
            "description": "Export parsed content data for external consumers"
        },
        {
            "name": "Health",
            "description": "Service health and diagnostics"
        },
        {
            "name": "HLS",
            "description": "HLS manifest retrieval for streaming integration"
        }
    ],
    "paths": {
        "/api/v1/parse/search": {
            "post": {
                "tags": [
                    "Parse"
                ],
                "summary": "Search and parse content from Kodik",
                "operationId": "search",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ParseRequestDto"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/ContentDto"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/parse/decode/{contentId}": {
            "post": {
                "tags": [
                    "Parse"
                ],
                "summary": "Decode mp4 links for every variant of the given content",
                "operationId": "decode",
                "parameters": [
                    {
                        "name": "contentId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "force",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "boolean",
                            "default": false
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/api/v1/parse/decode/variant/{variantId}": {
            "post": {
                "tags": [
                    "Parse"
                ],
                "summary": "Decode mp4 link for a single variant (used by the demo UI per-row Decode button)",
                "operationId": "decodeVariant",
                "parameters": [
                    {
                        "name": "variantId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "force",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "boolean",
                            "default": false
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "variantId": {
                                            "type": "integer",
                                            "format": "int64"
                                        },
                                        "decoded": {
                                            "type": "boolean"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/download/{variantId}": {
            "post": {
                "tags": [
                    "Download"
                ],
                "summary": "Start downloading a single variant (returns immediately, poll status via GET)",
                "operationId": "downloadVariant",
                "parameters": [
                    {
                        "name": "variantId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/DownloadState"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/download/content/{contentId}": {
            "post": {
                "tags": [
                    "Download"
                ],
                "summary": "Download all undecoded variants for a content item",
                "operationId": "downloadContent",
                "parameters": [
                    {
                        "name": "contentId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {}
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/stream/{variantId}": {
            "get": {
                "tags": [
                    "Stream"
                ],
                "summary": "Stream video \u2014 serves local file if downloaded, otherwise proxies from CDN",
                "operationId": "stream",
                "parameters": [
                    {
                        "name": "variantId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/api/v1/hls/{variantId}/url": {
            "get": {
                "tags": [
                    "HLS"
                ],
                "summary": "Get fresh m3u8 URL for a variant (requires fresh decode)",
                "operationId": "getHlsUrl",
                "parameters": [
                    {
                        "name": "variantId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/hls/{variantId}/manifest": {
            "get": {
                "tags": [
                    "HLS"
                ],
                "summary": "Get absolutized m3u8 manifest for a variant (fresh decode + download + absolutize)",
                "operationId": "getAbsolutizedManifest",
                "parameters": [
                    {
                        "name": "variantId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/vnd.apple.mpegurl": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/health": {
            "get": {
                "tags": [
                    "Health"
                ],
                "summary": "General health check",
                "operationId": "health",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {}
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/health/schema-drift": {
            "get": {
                "tags": [
                    "Health"
                ],
                "summary": "Kodik API schema drift detection status",
                "operationId": "schemaDrift",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {}
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/health/proxy": {
            "get": {
                "tags": [
                    "Health"
                ],
                "summary": "Proxy pool statistics",
                "operationId": "proxyHealth",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {}
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/health/decoder": {
            "get": {
                "tags": [
                    "Health"
                ],
                "summary": "Decoder health and statistics (PF6)",
                "operationId": "decoderHealth",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {}
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/export/{contentId}": {
            "get": {
                "tags": [
                    "Export"
                ],
                "summary": "Get full export package for specific content",
                "operationId": "getExportData",
                "parameters": [
                    {
                        "name": "contentId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ContentExportDto"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/export/ready": {
            "get": {
                "tags": [
                    "Export"
                ],
                "summary": "List content ready for export (with decoded mp4 links)",
                "operationId": "getReadyForExport",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 0
                        }
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 20
                        }
                    },
                    {
                        "name": "updatedSince",
                        "in": "query",
                        "description": "Only return content updated after this timestamp (ISO 8601)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date-time"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/PageResponseContentExportDto"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/download/{variantId}/status": {
            "get": {
                "tags": [
                    "Download"
                ],
                "summary": "Check download status for a variant",
                "operationId": "getStatus",
                "parameters": [
                    {
                        "name": "variantId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/DownloadState"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/content": {
            "get": {
                "tags": [
                    "Content"
                ],
                "summary": "List all content with pagination",
                "operationId": "findAll",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 0
                        }
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "default": 20
                        }
                    },
                    {
                        "name": "sortBy",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "id"
                        }
                    },
                    {
                        "name": "order",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "ASC"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/PageResponseContentDto"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/content/{id}": {
            "get": {
                "tags": [
                    "Content"
                ],
                "summary": "Get content by ID",
                "operationId": "findById",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ContentDto"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/content/{id}/variants": {
            "get": {
                "tags": [
                    "Content"
                ],
                "summary": "Get all episode variants for content",
                "operationId": "findVariants",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/EpisodeVariantDto"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/content/by-kinopoisk/{kinopoiskId}": {
            "get": {
                "tags": [
                    "Content"
                ],
                "summary": "Find content by Kinopoisk ID",
                "operationId": "findByKinopoiskId",
                "parameters": [
                    {
                        "name": "kinopoiskId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ContentDto"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ParseRequestDto": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string"
                    },
                    "kinopoiskId": {
                        "type": "string"
                    },
                    "imdbId": {
                        "type": "string"
                    },
                    "shikimoriId": {
                        "type": "string"
                    },
                    "decodeLinks": {
                        "type": "boolean"
                    }
                }
            },
            "ContentDto": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "kodikId": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "titleOrig": {
                        "type": "string"
                    },
                    "otherTitle": {
                        "type": "string"
                    },
                    "year": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "kinopoiskId": {
                        "type": "string"
                    },
                    "imdbId": {
                        "type": "string"
                    },
                    "shikimoriId": {
                        "type": "string"
                    },
                    "worldartLink": {
                        "type": "string"
                    },
                    "screenshots": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "materialData": {
                        "type": "object",
                        "additionalProperties": {}
                    },
                    "kinopoiskRating": {
                        "type": "number",
                        "format": "double"
                    },
                    "imdbRating": {
                        "type": "number",
                        "format": "double"
                    },
                    "shikimoriRating": {
                        "type": "number",
                        "format": "double"
                    },
                    "genres": {
                        "type": "string"
                    },
                    "blockedCountries": {
                        "type": "string"
                    },
                    "camrip": {
                        "type": "boolean"
                    },
                    "lgbt": {
                        "type": "boolean"
                    },
                    "lastSeason": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "lastEpisode": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "episodesCount": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "quality": {
                        "type": "string"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "DownloadState": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "string",
                        "enum": [
                            "PENDING",
                            "IN_PROGRESS",
                            "COMPLETED",
                            "FAILED"
                        ]
                    },
                    "filepath": {
                        "type": "string"
                    },
                    "error": {
                        "type": "string"
                    },
                    "totalSegments": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "downloadedSegments": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "totalBytes": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "expectedTotalBytes": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Content-Length of the final 2xx response on the WebClient path; null for HLS downloads where progress is tracked via totalSegments/downloadedSegments."
                    }
                }
            },
            "ContentExportDto": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "type": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "titleOrig": {
                        "type": "string"
                    },
                    "otherTitle": {
                        "type": "string"
                    },
                    "year": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "kinopoiskId": {
                        "type": "string"
                    },
                    "imdbId": {
                        "type": "string"
                    },
                    "shikimoriId": {
                        "type": "string"
                    },
                    "posterUrl": {
                        "type": "string",
                        "description": "Kinopoisk poster URL extracted from Kodik material_data (poster_url_original preferred over poster_url). Null if material_data is missing or has no poster fields."
                    },
                    "screenshots": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "camrip": {
                        "type": "boolean"
                    },
                    "lgbt": {
                        "type": "boolean"
                    },
                    "seasons": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/SeasonExportDto"
                        }
                    }
                }
            },
            "EpisodeExportDto": {
                "type": "object",
                "properties": {
                    "episodeNumber": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "variants": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/VariantExportDto"
                        }
                    }
                }
            },
            "SeasonExportDto": {
                "type": "object",
                "properties": {
                    "seasonNumber": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "episodes": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/EpisodeExportDto"
                        }
                    }
                }
            },
            "VariantExportDto": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "translationId": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "translationTitle": {
                        "type": "string"
                    },
                    "translationType": {
                        "type": "string"
                    },
                    "quality": {
                        "type": "string"
                    },
                    "mp4Link": {
                        "type": "string"
                    }
                }
            },
            "PageResponseContentExportDto": {
                "type": "object",
                "properties": {
                    "content": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ContentExportDto"
                        }
                    },
                    "page": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "size": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "totalElements": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "totalPages": {
                        "type": "integer",
                        "format": "int32"
                    }
                }
            },
            "PageResponseContentDto": {
                "type": "object",
                "properties": {
                    "content": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ContentDto"
                        }
                    },
                    "page": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "size": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "totalElements": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "totalPages": {
                        "type": "integer",
                        "format": "int32"
                    }
                }
            },
            "EpisodeVariantDto": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "contentId": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "seasonNumber": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "episodeNumber": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "translationId": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "translationTitle": {
                        "type": "string"
                    },
                    "translationType": {
                        "type": "string"
                    },
                    "quality": {
                        "type": "string"
                    },
                    "kodikLink": {
                        "type": "string"
                    },
                    "mp4Link": {
                        "type": "string"
                    },
                    "localFilepath": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
